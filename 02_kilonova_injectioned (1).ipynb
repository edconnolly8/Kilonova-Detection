   ],
   "source": [
    "M_abs = -16\n",
    "\n",
    "events[\"mu\"] = 5 * np.log10(events[\"distance\"]*1e6) - 5\n",
    "events[\"m\"] = M_abs + events[\"mu\"]\n",
    "\n",
    "events.head()"
   ]
