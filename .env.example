# ── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Job Board APIs ───────────────────────────────────────────────────────────
# Adzuna (free tier): https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# SerpAPI (Google Jobs): https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# ── User Profile ─────────────────────────────────────────────────────────────
USER_NAME="Your Full Name"
USER_EMAIL="you@email.com"
USER_PHONE="+353 xx xxx xxxx"
USER_LOCATION="Dublin, Ireland"

# ── Agent Settings ───────────────────────────────────────────────────────────
# Max applications to submit per day
MAX_APPLICATIONS_PER_DAY=10

# Minimum relevance score (0.0–1.0) to attempt application
MIN_SCORE_THRESHOLD=0.65

# Set to true to discover + score only, without submitting any applications
DRY_RUN=false

# Path to resume file (Markdown)
RESUME_PATH=resume.md

# Path to SQLite database file
DB_PATH=jobs.db
